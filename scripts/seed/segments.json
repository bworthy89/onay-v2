    "usage_count": 0,
    "audio_url": "/segments/SEG-SEED-00030-T1/audio.wav",
    "script_text": "Here's something wild — Frank Ocean originally released Blonde exclusively on his own website, bypassing his label entirely. Moves like that changed how artists think about independence."
  },
  {
    "segment_id": "SEG-SEED-00031-T1",
    "type": "fun_fact",
    "genre_tags": ["hip-hop", "r&b"],
    "mood_tags": ["throwback", "nostalgia"],
    "artist_refs": ["The Notorious B.I.G."],
    "energy_level": 3,
