    "quality_score": 0.87,
    "exaggeration_level": 0.3,
    "created_at": "2026-03-28T00:00:00.000Z",
    "usage_count": 0,
    "audio_url": "/segments/SEG-SEED-00032-T1/audio.wav",
    "script_text": "J Dilla made Donuts, his masterpiece, from a hospital bed. He passed three days after it dropped. That album is pure love in beat form."
  },
  {
    "segment_id": "SEG-SEED-00033-T1",
    "type": "fun_fact",
    "genre_tags": ["hip-hop", "trap"],
    "mood_tags": ["workout", "energetic"],
    "artist_refs": ["Eminem"],
    "energy_level": 4,
