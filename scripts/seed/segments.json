    "audio_url": "/segments/SEG-SEED-00029-T1/audio.wav",
    "script_text": "Fun fact — Kendrick Lamar won a Pulitzer Prize for DAMN. First non-jazz, non-classical artist to ever do that. Let that sink in."
  },
  {
    "segment_id": "SEG-SEED-00030-T1",
    "type": "fun_fact",
    "genre_tags": ["r&b"],
    "mood_tags": ["chill", "late-night"],
    "artist_refs": ["Frank Ocean"],
    "energy_level": 2,
