    "quality_score": 0.86,
    "exaggeration_level": 0.6,
    "created_at": "2026-03-28T00:00:00.000Z",
    "usage_count": 0,
    "audio_url": "/segments/SEG-SEED-00033-T1/audio.wav",
    "script_text": "Did you know Lose Yourself was the first rap song to win an Oscar? Eminem wasn't even at the ceremony — he was at home sleeping. Legend stuff."
  },
  {
    "segment_id": "SEG-SEED-00034-T1",
