    "exaggeration_level": 0.5,
    "created_at": "2026-03-28T00:00:00.000Z",
    "usage_count": 0,
    "audio_url": "/segments/SEG-SEED-00031-T1/audio.wav",
    "script_text": "Fun fact — Biggie wrote most of his rhymes in his head. Rarely used pen and paper. That level of memory and flow? Unmatched."
  },
  {
    "segment_id": "SEG-SEED-00032-T1",
    "type": "fun_fact",
    "genre_tags": ["lo-fi", "chill"],
    "mood_tags": ["chill", "focus"],
    "artist_refs": ["J Dilla"],
    "energy_level": 2,
