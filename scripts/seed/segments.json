    "usage_count": 0,
    "audio_url": "/segments/SEG-SEED-00034-T1/audio.wav",
    "script_text": "Hot take — features are overrated. The best albums? Solo. No features. Just one artist, one vision, no compromises. Fight me."
  },
  {
    "segment_id": "SEG-SEED-00035-T1",
